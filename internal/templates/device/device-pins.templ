package device

import (
	"fmt"

	"github.com/knackwurstking/picow-led/internal/templates/components/templui/button"
	"github.com/knackwurstking/picow-led/internal/templates/components/templui/form"
	"github.com/knackwurstking/picow-led/internal/templates/components/templui/input"
	"github.com/knackwurstking/picow-led/internal/urlb"
	"github.com/knackwurstking/picow-led/internal/utils"
	"github.com/knackwurstking/picow-led/pkg/models"
	"strings"
)

type PinsFormProps struct {
	ID         string
	Class      string
	Attributes templ.Attributes

	DeviceID   models.ID
	DeviceType models.DeviceType
	Pins       []uint8
	Readonly   bool
}

templ PinsForm(props ...PinsFormProps) {
	{{
		p := PinsFormProps{}
		if len(props) > 0 {
			p = props[0]
		}

		if p.ID == "" {
			p.ID = utils.RandomID()
		}
	}}
	<form
		if p.ID != "" {
			id={ p.ID }
		}
		class={
			"space-y-4",
			p.Class,
		}
		enctype="multipart/form-data"
		hx-post={ urlb.DevicePins(p.DeviceID) }
		hx-target={ "#" + p.ID }
		hx-swap="outerHTML"
		hx-trigger="submit"
		{ p.Attributes... }
	>
		<div class="flex flex-row flex-wrap gap-4">
			for i, pin := range strings.Split(string(p.DeviceType), "") {
				@form.Item(form.ItemProps{
					Class: "flex-1 min-w-[120px]",
				}) {
					@form.Label() {
						{ pin }
					}
					{{
						value := ""
						if i < len(p.Pins) {
							value = fmt.Sprintf("%d", p.Pins[i])
						}
					}}
					{{ id := fmt.Sprintf("%s-pin", p.ID) }}
					@input.Input(input.Props{
						ID:       id,
						Name:     id,
						Type:     input.TypeNumber,
						Value:    value,
						Readonly: p.Readonly,
						Attributes: templ.Attributes{
							"min": 0,
							"max": 40,
						},
					})
				}
			}
		</div>
		<div class="flex justify-end">
			@button.Button(button.Props{
				Type: button.TypeSubmit,
			}) {
				Aktualisieren
			}
		</div>
	</form>
}
