package htmx

import (
	"fmt"
	"github.com/knackwurstking/picow-led/internal/components/button"
	"github.com/knackwurstking/picow-led/internal/components/icon"
	"github.com/knackwurstking/picow-led/internal/urlb"
	"github.com/knackwurstking/picow-led/pkg/models"
)

const (
	IDDeviceItem = "device-item-%d"
)

type DevicesProps struct {
	Data []*models.Device
}

templ Devices(props ...DevicesProps) {
	{{
		prop := DevicesProps{}
		if len(props) > 0 {
			prop = props[0]
		}
	}}
	for _, d := range prop.Data {
		@DeviceItem(d)
	}
}

templ DeviceItem(d *models.Device) {
	<div id={ fmt.Sprintf(IDDeviceItem, d.ID) } class="device-item bg-gray-100 p-4 rounded">
		<div class="flex items-center gap-4 mb-2">
			<span class="w-full">
				<div class="font-bold">{ d.Name }</div>
				<div class="text-sm text-gray-600">{ d.Addr }</div>
			</span>
			<span class="w-fit">
				@button.Button(button.Props{
					Variant: button.VariantOutline,
					Size:    button.SizeIcon,
					Href:    urlb.EditDeviceDialog(d.ID),
				}) {
					@icon.Pen()
				}
				// TODO: Switch component for toggling device ON or OFF
			</span>
		</div>
	</div>
}
