package views

import (
	"github.com/knackwurstking/picow-led/internal/components/layout"
	"github.com/knackwurstking/picow-led/internal/components/tabs"
	"github.com/knackwurstking/picow-led/internal/env"
)

const (
	IDTabsNav     = "tabs-nav"
	IDTabsContent = "tabs-content"
)

templ HomePage() {
	@layout.Layout(layout.Props{
		Class: "px-4",
		Lang:  "de",
		Title: "PicoW LED",
	}) {
		@tabs.Tabs(tabs.Props{
			ID: IDTabsNav,
		}) {
			@tabs.List(tabs.ListProps{
				Class: "w-full",
			}) {
				@tabs.Trigger(tabs.TriggerProps{
					Value: "devices",
				}) {
					Geräte
				}
				@tabs.Trigger(tabs.TriggerProps{
					Value: "groups",
				}) {
					Gruppen
				}
				@tabs.Trigger(tabs.TriggerProps{
					Value: "scenes",
					Attributes: templ.Attributes{
						"disabled": true,
					},
				}) {
					Szenen
				}
			}
			<main id={ IDTabsContent }>
				@tabs.Content(tabs.ContentProps{
					Value: "devices",
				}) {
					<section
						class="flex flex-col gap-4"
						hx-get={ env.Route("/htmx/devices") }
						hx-trigger="load"
						hx-swap="innerHTML"
					></section>
				}
				@tabs.Content(tabs.ContentProps{
					Value: "groups",
				}) {
					// TODO: ...
				}
			</main>
		}
	}
}
